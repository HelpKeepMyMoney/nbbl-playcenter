# Firebase (Web app config from Project settings)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
# Must match Firebase Console project id exactly (this repo: nbbl-playcenter — letter "l", not digit "1")
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Region for callable Cloud Functions (must match deployment; default us-central1)
# VITE_FIREBASE_FUNCTIONS_REGION=us-central1

# Optional: absolute origin of the deployed site (no trailing slash) if the SPA is not same-origin
# as the API (e.g. static hosting elsewhere). Leave unset on Vercel when the app and /api share one URL.
# VITE_APP_ORIGIN=https://your-deployment.vercel.app

# --- Cloud Functions (not read by Vite): set in GCP / Firebase ---
# firebase functions:secrets:set RESEND_API_KEY   (same Resend key as the NBBL project)

# --- Vercel serverless only (`api/constant-contact-sync.js`) — add these in Vercel → Settings → Environment Variables ---
# Or put them in repo root `.env` for local `vercel dev` (never prefix with VITE_; never commit real values).
# CONSTANT_CONTACT_CLIENT_ID=
# CONSTANT_CONTACT_CLIENT_SECRET=
# CONSTANT_CONTACT_REFRESH_TOKEN=
# CONSTANT_CONTACT_LIST_ID=          # one list UUID, or use CONSTANT_CONTACT_LIST_IDS=id1,id2
# CONSTANT_CONTACT_LIST_IDS=
# FIREBASE_SERVICE_ACCOUNT_KEY=      # single-line JSON for a GCP service account (Firestore read/write on users/*)
