# Firebase (Web app config from Project settings)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
# Must match Firebase Console project id exactly (this repo: nbbl-playcenter — letter "l", not digit "1")
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Region for callable Cloud Functions (must match deployment; default us-central1)
# VITE_FIREBASE_FUNCTIONS_REGION=us-central1

# --- Cloud Functions (not read by Vite): set in GCP / Firebase, not necessarily in this file ---
# firebase functions:secrets:set RESEND_API_KEY   (same Resend key as the NBBL project)
