rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin(uid) {
      return exists(/databases/$(database)/documents/admins/$(uid));
    }

    function legacyPublished(data) {
      return data.get('isPublic', false) == true
        && data.get('communityVisibility', '') == '';
    }

    function communityReadable(data) {
      return data.get('communityVisibility', '') == 'published'
        || legacyPublished(data);
    }

    function clipImmutableKeys() {
      return ['userId', 'title', 'category', 'videoStoragePath',
        'thumbnailStoragePath', 'durationSec', 'createdAt', 'tags', 'ownerDisplayName', 'likeCount'];
    }

    function canReadClipData(data) {
      return request.auth != null && (
        request.auth.uid == data.userId
        || communityReadable(data)
        || isAdmin(request.auth.uid)
      );
    }

    function ownerMayNotChangeModeration(aff) {
      return !aff.hasAny(['moderationRejectionReason', 'moderatedAt', 'moderatedBy']);
    }

    function ownerVisibilityOk() {
      let prevVis = resource.data.get('communityVisibility', '');
      let prevEffective = prevVis != '' ? prevVis
        : (resource.data.get('isPublic', false) == true ? 'published' : 'private');
      let nextVis = request.resource.data.communityVisibility;
      return nextVis in ['private', 'pending', 'published', 'rejected']
        && !(nextVis == 'published' && prevEffective != 'published')
        && !(nextVis == 'rejected');
    }

    match /admins/{adminId} {
      allow read: if request.auth != null && (
        request.auth.uid == adminId
        || isAdmin(request.auth.uid)
      );
      allow write: if false;
    }

    function userProfileFieldsValid() {
      return request.resource.data.displayName is string
        && request.resource.data.displayName.size() < 200
        && request.resource.data.email is string
        && request.resource.data.email.size() < 320
        && (request.resource.data.photoURL == null
          || (request.resource.data.photoURL is string
            && request.resource.data.photoURL.size() < 2048))
        && request.resource.data.city is string
        && request.resource.data.city.size() < 120
        && request.resource.data.updatedAt is timestamp;
    }

    match /users/{userId} {
      allow read: if request.auth != null;

      allow create: if request.auth != null
        && request.auth.uid == userId
        && userProfileFieldsValid()
        && request.resource.data.createdAt is timestamp
        && request.resource.data.keys().hasAll([
          'displayName', 'email', 'photoURL', 'city', 'updatedAt', 'createdAt'
        ]);

      allow update: if request.auth != null
        && userProfileFieldsValid()
        && request.resource.data.createdAt == resource.data.createdAt
        && (
          request.auth.uid == userId
          || isAdmin(request.auth.uid)
        );

      allow delete: if request.auth != null && isAdmin(request.auth.uid);
    }

    match /clips/{clipId} {
      allow read: if request.auth != null && (
        request.auth.uid == resource.data.userId ||
        communityReadable(resource.data) ||
        isAdmin(request.auth.uid)
      );

      allow delete: if request.auth != null
        && (
          request.auth.uid == resource.data.userId
          || isAdmin(request.auth.uid)
        );

      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.userId
        && request.resource.data.keys().hasAll([
          'userId', 'title', 'category', 'videoStoragePath',
          'thumbnailStoragePath', 'durationSec', 'createdAt', 'tags',
          'communityVisibility', 'moderationRejectionReason', 'ownerDisplayName', 'likeCount'
        ])
        && request.resource.data.communityVisibility in ['private', 'pending']
        && request.resource.data.moderationRejectionReason is string
        && request.resource.data.moderationRejectionReason.size() < 4000
        && request.resource.data.ownerDisplayName is string
        && request.resource.data.ownerDisplayName.size() < 200
        && request.resource.data.likeCount is int
        && request.resource.data.likeCount == 0;

      allow update: if request.auth != null
        && canReadClipData(resource.data)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likeCount'])
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.likeCount is int
        && request.resource.data.likeCount >= 0
        && (
          request.resource.data.likeCount == resource.data.get('likeCount', 0) + 1
          || (
            request.resource.data.likeCount == resource.data.get('likeCount', 0) - 1
            && resource.data.get('likeCount', 0) >= 1
          )
        );

      allow update: if request.auth != null
        && request.auth.uid == resource.data.userId
        && request.resource.data.userId == resource.data.userId
        && ownerMayNotChangeModeration(
          request.resource.data.diff(resource.data).affectedKeys())
        && (
          (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['communityVisibility'])
            && ownerVisibilityOk())
          || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['ownerDisplayName'])
            && request.resource.data.ownerDisplayName is string
            && request.resource.data.ownerDisplayName.size() < 200)
        );

      allow update: if request.auth != null
        && isAdmin(request.auth.uid)
        && request.resource.data.userId == resource.data.userId
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(clipImmutableKeys())
        && request.resource.data.communityVisibility in ['private', 'pending', 'published', 'rejected']
        && request.resource.data.moderationRejectionReason is string
        && request.resource.data.moderationRejectionReason.size() < 4000;

      match /likes/{likerId} {
        allow read: if request.auth != null
          && canReadClipData(get(/databases/$(database)/documents/clips/$(clipId)).data);
        allow create: if request.auth != null
          && request.auth.uid == likerId
          && canReadClipData(get(/databases/$(database)/documents/clips/$(clipId)).data)
          && request.resource.data.keys().hasOnly(['createdAt'])
          && request.resource.data.createdAt is timestamp;
        allow delete: if request.auth != null
          && (
            request.auth.uid == likerId
            || request.auth.uid == get(/databases/$(database)/documents/clips/$(clipId)).data.userId
            || isAdmin(request.auth.uid)
          );
      }
    }
  }
}
